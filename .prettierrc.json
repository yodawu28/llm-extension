{
  "semi": false,
  "singleQuote": false,
  "trailingComma": "none",
  "tabWidth": 2,
  "printWidth": 100,
  "plugins": ["@ianvs/prettier-plugin-sort-imports"],
  "importOrder": [
    "^(react/(.*)$)|^(react$)",
    "^(plasmo/(.*)$)|^(plasmo$)",
    "<THIRD_PARTY_MODULES>",
    "^~(.*)$",
    "^[./]"
  ]
}
