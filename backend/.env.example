APP_NAME=Web Context Assistant API
DEBUG=false

LLM_PROVIDER=openai
HYBRID_CLOUD_PROVIDER=openai
HYBRID_PREFILTER_ENABLED=true
HYBRID_PREFILTER_MAX_CHUNKS=4
HYBRID_PREFILTER_MAX_CHARS_PER_CHUNK=420
HYBRID_PREFILTER_TIMEOUT_SECONDS=20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MODEL_SUMMARY=
OPENAI_MODEL_REASONING=
OPENAI_BASE_URL=
PAT_TOKEN=
# Use http://127.0.0.1:11434 when the backend runs on the host.
# Use http://host.docker.internal:11434 when the backend runs in Docker.
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL_SUMMARY=gemma2:2b
OLLAMA_MODEL_REASONING=deepseek-coder-v2:16b-lite-instruct
OLLAMA_REQUEST_TIMEOUT_SECONDS=45
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_EMBEDDING_DIMENSIONS=1536
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
LOCAL_EMBEDDING_DIMENSIONS=384

# Internal gateway example:
# AWS_GATEWAY_URL=
# PAT_TOKEN=
# MODEL_PROVIDER=
# MODEL=gpt-5.2-codex
# MODEL_REASONING_EFFORT=xhigh
# EMBEDDING_PROVIDER=local

# Local Ollama example:
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL_SUMMARY=gemma2:2b
# OLLAMA_MODEL_REASONING=deepseek-coder-v2:16b-lite-instruct
# EMBEDDING_PROVIDER=local

# Hybrid example (local prefilter + cloud answer):
# LLM_PROVIDER=hybrid
# HYBRID_CLOUD_PROVIDER=openai
# PAT_TOKEN=
# AWS_GATEWAY_URL=
# OPENAI_MODEL_SUMMARY=gpt-4o-mini
# OPENAI_MODEL_REASONING=o4-mini
# OLLAMA_BASE_URL=http://host.docker.internal:11434
# OLLAMA_MODEL_SUMMARY=gemma2:2b
# HYBRID_PREFILTER_MAX_CHUNKS=4

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_MODEL_SUMMARY=
ANTHROPIC_MODEL_REASONING=

MAX_INPUT_TOKENS=100000
MAX_OUTPUT_TOKENS=4096
REQUEST_TIMEOUT_SECONDS=120
LOG_LEVEL=INFO

RERANKER_ENABLED=false
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2
RERANKER_TOP_K=12
RERANKER_USE_SUBPROCESS=true
RERANKER_STARTUP_TIMEOUT_SECONDS=8
RERANKER_INFERENCE_TIMEOUT_SECONDS=12

CORS_ORIGINS=["chrome-extension://*"]
