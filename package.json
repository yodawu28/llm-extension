{
  "name": "web-context-assistant",
  "displayName": "Web Context Assistant",
  "version": "0.1.0",
  "description": "AI-powered assistant for any webpage - pin pages and ask questions",
  "author": "Long Vo",
  "license": "MIT",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "pnpm build && node scripts/package-extension.mjs",
    "package:plasmo": "plasmo package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.2.2",
    "mermaid": "^10.9.1",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "^4.4.0",
    "@types/chrome": "^0.0.277",
    "@types/dompurify": "^3.2.0",
    "@types/node": "^22.13.1",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "host_permissions": [
      "<all_urls>"
    ],
    "permissions": [
      "storage",
      "activeTab",
      "scripting",
      "sidePanel",
      "tabs",
      "offscreen",
      "windows",
      "notifications"
    ],
    "side_panel": {
      "default_path": "sidepanel.html"
    }
  }
}
